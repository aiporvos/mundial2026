generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  password           String
  name               String
  lastName           String
  dni                String?
  phone              String?
  emailVerified      Boolean             @default(false)
  role               String              @default("USER")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  orders             Order[]
  albumItems         AlbumItem[]
  verificationTokens VerificationToken[]
  sessions           Session[]
  listings           UserListing[]
  creditBalance      CreditBalance?
  creditPurchases    CreditPurchase[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Figurita {
  id         String      @id @default(cuid())
  number     Int         @unique
  name       String
  team       String
  rarity     String      @default("COMUN")
  price      Int
  stock      Int         @default(0)
  imageUrl   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  orderItems OrderItem[]
  albumItems AlbumItem[]
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  guestEmail    String?
  guestName     String?
  guestLastName String?
  guestDni      String?
  guestPhone    String?
  status        String      @default("PENDING_PAYMENT")
  total         Int
  pickupCode    String      @unique
  reservedUntil DateTime
  paidAt        DateTime?
  collectedAt   DateTime?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User?       @relation(fields: [userId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  figuritaId String
  quantity   Int
  price      Int

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  figurita   Figurita @relation(fields: [figuritaId], references: [id])
}

model UserListing {
  id          String   @id @default(cuid())
  userId      String
  number      Int
  name        String
  team        String
  imageUrl    String?
  askingPrice Int
  whatsapp    String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditBalance {
  id             String    @id @default(cuid())
  userId         String    @unique
  credits        Int       @default(5)
  isUnlimited    Boolean   @default(false)
  unlimitedUntil DateTime?

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditPurchase {
  id        String   @id @default(cuid())
  userId    String
  packKey   String
  credits   Int
  amount    Int
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AlbumItem {
  id         String   @id @default(cuid())
  userId     String
  figuritaId String
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  figurita   Figurita @relation(fields: [figuritaId], references: [id])

  @@unique([userId, figuritaId])
}
